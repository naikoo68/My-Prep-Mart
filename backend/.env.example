# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/mystudyguide

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary (file/image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# Admin bootstrap (creates/recovers an admin account on startup)
ADMIN_EMAIL=admin@mystudyguide.com
ADMIN_PASSWORD=admin123
# ADMIN_RESET=true   # set temporarily to reset an existing admin's password

# Email notifications (contact form). Example uses Gmail SMTP with an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your_gmail_address@gmail.com
# Where contact-form notifications are sent (defaults to SMTP_USER if unset)
NOTIFY_EMAIL=adilnaik19@gmail.com


# AI Question Generator (optional) — powers the "Generate with AI" button in the admin panel.
# Works with any OpenAI-compatible provider (TokenLab, OpenAI, Groq, DeepSeek, ...).
# Leave AI_API_KEY unset to disable the feature.
AI_API_KEY=your_tokenlab_api_key
AI_BASE_URL=https://api.tokenlab.sh/v1
# One OR many model ids, comma-separated. The first is the default; the admin
# can pick any of them from a dropdown. Example:
# AI_MODEL=gpt-4o-mini, llama-3.3-70b, deepseek-chat
AI_MODEL=gpt-4o-mini
